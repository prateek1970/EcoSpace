<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Echo Showcase Hub | Music Creator & Acoustic Showcase</title>
  <meta name="description" content="Discover, showcase, and collaborate on acoustic covers, original tracks, and jam sessions.">
  
  <!-- Bootstrap 5 CSS CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  
  <!-- Bootstrap Icons CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-dark text-light d-flex flex-column min-vh-100 position-relative">

  <!-- Ambient Glass Background Glowing Orbs -->
  <div class="ambient-glow-container">
    <div class="ambient-orb ambient-orb-1"></div>
    <div class="ambient-orb ambient-orb-2"></div>
    <div class="ambient-orb ambient-orb-3"></div>
  </div>

  <!-- Include Navbar -->
  <%- include('partials/navbar') %>

  <!-- Hero Section -->
  <header class="hero-wrapper py-5 text-center position-relative overflow-hidden">
    <div class="container py-4">
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <div class="hero-glass-box p-4 p-md-5 shadow-lg position-relative overflow-hidden">
            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold text-uppercase tracking-wider mb-3 shadow-sm">
              <i class="bi bi-mic-fill me-1"></i> Music Creator Hub
            </span>
            <h1 class="display-4 fw-extrabold text-light mb-3">
              Acoustic Showcase & <span class="text-warning">Collab Network</span>
            </h1>
            <p class="lead text-secondary mb-4 mx-auto" style="max-width: 680px;">
              Listen to raw acoustic covers, original demos, and jam sessions. Connect with vocalists, guitarists, and producers to create your next release.
            </p>

            <!-- Hero Quick Stats -->
            <div class="d-flex flex-wrap align-items-center justify-content-center gap-3 gap-md-4 py-3 mb-4">
              <div class="stat-pill px-4 py-2 rounded-pill d-flex align-items-center gap-2">
                <i class="bi bi-music-note-beamed text-warning fs-4"></i>
                <div class="text-start">
                  <div class="fw-bold text-light lh-1"><%= stats.totalTracks %></div>
                  <small class="text-muted" style="font-size: 0.75rem;">Tracks Shared</small>
                </div>
              </div>
              <div class="stat-pill px-4 py-2 rounded-pill d-flex align-items-center gap-2">
                <i class="bi bi-people-fill text-info fs-4"></i>
                <div class="text-start">
                  <div class="fw-bold text-light lh-1"><%= stats.totalCollabs %></div>
                  <small class="text-muted" style="font-size: 0.75rem;">Collab Calls</small>
                </div>
              </div>
              <div class="stat-pill px-4 py-2 rounded-pill d-flex align-items-center gap-2">
                <i class="bi bi-heart-fill text-danger fs-4"></i>
                <div class="text-start">
                  <div class="fw-bold text-light lh-1"><%= stats.totalLikes %></div>
                  <small class="text-muted" style="font-size: 0.75rem;">Total Likes</small>
                </div>
              </div>
            </div>

            <!-- Hero Action Buttons -->
            <div class="d-flex flex-wrap justify-content-center gap-3">
              <a href="#tracks-section" class="btn btn-warning btn-lg fw-bold rounded-pill px-4 shadow">
                <i class="bi bi-play-circle-fill me-1"></i> Explore Tracks
              </a>
              <a href="#collab-section" class="btn btn-glass btn-lg rounded-pill px-4">
                <i class="bi bi-mic me-1"></i> Post Collab Call
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Notification Banner if Form Submitted -->
  <% if (isSubmitted) { %>
    <div class="container mt-4">
      <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 rounded-4" role="alert">
        <i class="bi bi-check-circle-fill fs-4"></i>
        <div>
          <strong>Collab Request Submitted!</strong> Your request has been posted on the Collaboration Hub. Creators will get in touch with you.
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    </div>
  <% } %>

  <!-- Main Content Container -->
  <main class="container py-5">
    
    <!-- Tracks Showcase Section Header & Filter Controls -->
    <section id="tracks-section" class="mb-5">
      <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <div>
          <h2 class="h3 fw-bold text-light mb-1 d-flex align-items-center gap-2">
            <i class="bi bi-disc-fill text-warning"></i> Acoustic Tracks Showcase
          </h2>
          <p class="text-muted small mb-0">Discover community recordings, acoustic arrangements, and fresh snippets</p>
        </div>

        <!-- Search Form -->
        <form action="/" method="GET" class="d-flex gap-2" style="max-width: 380px; width: 100%;">
          <% if (selectedCategory) { %>
            <input type="hidden" name="category" value="<%= selectedCategory %>">
          <% } %>
          <div class="input-group">
            <span class="input-group-text">
              <i class="bi bi-search"></i>
            </span>
            <input type="text" name="search" class="form-control echo-input" placeholder="Search track or artist..." value="<%= searchQuery %>">
            <button class="btn btn-warning fw-bold px-3 rounded-end-3" type="submit">Search</button>
          </div>
        </form>
      </div>

      <!-- Category Filter Pills -->
      <div class="d-flex flex-wrap gap-2 mb-4 pb-2 border-bottom border-secondary border-opacity-25">
        <a href="/" class="btn btn-sm rounded-pill px-3 <%= !selectedCategory ? 'btn-warning text-dark fw-bold shadow-sm' : 'btn-glass text-light' %>">
          <i class="bi bi-grid-fill me-1"></i> All Tracks
        </a>
        <% categories.forEach(cat => { %>
          <a href="/?category=<%= encodeURIComponent(cat) %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>" 
             class="btn btn-sm rounded-pill px-3 <%= selectedCategory === cat ? 'btn-warning text-dark fw-bold shadow-sm' : 'btn-glass text-light' %>">
            <% if (cat === 'Acoustic Cover') { %><i class="bi bi-guitar me-1"></i><% } %>
            <% if (cat === 'Original Song') { %><i class="bi bi-music-note-list me-1"></i><% } %>
            <% if (cat === 'Jam Session') { %><i class="bi bi-sliders me-1"></i><% } %>
            <% if (cat === 'Snippet') { %><i class="bi bi-lightning-charge me-1"></i><% } %>
            <%= cat %>
          </a>
        <% }); %>
      </div>

      <!-- Tracks Grid -->
      <% if (tracks.length === 0) { %>
        <div class="text-center py-5 glass-panel rounded-4 my-4">
          <i class="bi bi-soundwave display-1 text-secondary opacity-50 mb-3 d-block"></i>
          <h4 class="text-light fw-bold">No Tracks Found</h4>
          <p class="text-muted max-w-md mx-auto">
            <%= searchQuery ? 'No tracks match your search criteria.' : 'No tracks available in this category yet.' %>
          </p>
          <a href="/" class="btn btn-glass rounded-pill px-4 mt-2">Reset Filters</a>
        </div>
      <% } else { %>
        <div class="row g-4">
          <% tracks.forEach(track => { %>
            <div class="col-lg-6 col-md-6 col-12">
              <div class="card track-card h-100 shadow position-relative overflow-hidden">
                <!-- Card Header -->
                <div class="card-header card-header-gradient p-3 d-flex align-items-center justify-content-between">
                  <div class="d-flex align-items-center gap-2 overflow-hidden me-2">
                    <div class="avatar-box bg-dark text-warning rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px; border: 1px solid rgba(255, 255, 255, 0.15);">
                      <i class="bi bi-vinyl fs-5"></i>
                    </div>
                    <div class="text-truncate">
                      <h5 class="card-title text-light fw-bold mb-0 text-truncate"><%= track.title %></h5>
                      <span class="text-warning small fw-semibold">
                        <i class="bi bi-person-fill me-1"></i><%= track.artistName %>
                      </span>
                    </div>
                  </div>

                  <!-- Category Badge -->
                  <% 
                    let badgeClass = 'badge-category-acoustic-cover';
                    if (track.category === 'Original Song') badgeClass = 'badge-category-original-song';
                    if (track.category === 'Jam Session') badgeClass = 'badge-category-jam-session';
                    if (track.category === 'Snippet') badgeClass = 'badge-category-snippet';
                  %>
                  <span class="badge <%= badgeClass %> rounded-pill px-3 py-2 flex-shrink-0">
                    <%= track.category %>
                  </span>
                </div>

                <!-- Card Body -->
                <div class="card-body p-3 d-flex flex-column justify-content-between">
                  <% if (track.description) { %>
                    <p class="card-text text-secondary small mb-3">
                      <%= track.description %>
                    </p>
                  <% } %>

                  <!-- Embedded Audio Player -->
                  <div class="audio-player-wrapper mb-3 p-2">
                    <audio controls class="w-100" preload="metadata">
                      <source src="<%= track.audioUrl %>" type="audio/mpeg">
                      Your browser does not support HTML5 audio player.
                    </audio>
                  </div>

                  <!-- Tags & Interactive Like Action -->
                  <div class="d-flex align-items-center justify-content-between pt-2 border-top border-secondary border-opacity-25">
                    <div class="tags-container d-flex flex-wrap gap-1">
                      <% if (track.tags && track.tags.length > 0) { %>
                        <% track.tags.forEach(tag => { %>
                          <span class="badge bg-dark bg-opacity-50 text-secondary border border-secondary border-opacity-25" style="font-size: 0.7rem;">#<%= tag %></span>
                        <% }); %>
                      <% } else { %>
                        <span class="badge bg-dark bg-opacity-50 text-muted border border-secondary border-opacity-25" style="font-size: 0.7rem;">#acoustic</span>
                      <% } %>
                    </div>

                    <!-- AJAX Like Button -->
                    <button class="btn btn-sm btn-like rounded-pill px-3 py-1 d-flex align-items-center gap-2" data-track-id="<%= track._id %>">
                      <i class="bi bi-heart text-danger"></i>
                      <span class="fw-bold like-count"><%= track.likes %></span>
                    </button>
                  </div>
                </div>

                <!-- Footer timestamp -->
                <div class="card-footer card-footer-glass border-0 text-muted small px-3 py-2 d-flex justify-content-between align-items-center">
                  <span style="font-size: 0.75rem;">
                    <i class="bi bi-calendar3 me-1"></i><%= new Date(track.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </span>
                  <a href="<%= track.audioUrl %>" target="_blank" rel="noopener noreferrer" class="text-secondary text-hover-warning text-decoration-none" style="font-size: 0.75rem;">
                    Direct Link <i class="bi bi-box-arrow-up-right ms-1"></i>
                  </a>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Collaboration Board Section -->
    <section id="collab-section" class="pt-4">
      <div class="row g-4 align-items-start">
        
        <!-- Left Column: Active Collab Calls Display -->
        <div class="col-lg-7">
          <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
              <h3 class="h4 fw-bold text-light mb-1 d-flex align-items-center gap-2">
                <i class="bi bi-people-fill text-info"></i> Open Collaboration Calls
              </h3>
              <p class="text-muted small mb-0">Connect with fellow musicians looking for talent</p>
            </div>
            <span class="badge bg-info text-dark rounded-pill px-3 py-2 fw-bold"><%= collabRequests.length %> Active</span>
          </div>

          <% if (collabRequests.length === 0) { %>
            <div class="p-4 glass-panel rounded-4 text-center">
              <i class="bi bi-chat-quote text-secondary fs-1 mb-2 d-block"></i>
              <p class="text-muted mb-0">No active collaboration requests right now. Be the first to start a project!</p>
            </div>
          <% } else { %>
            <div class="row g-3">
              <% collabRequests.forEach(collab => { %>
                <div class="col-12">
                  <div class="card collab-card p-3 shadow">
                    <div class="d-flex align-items-start justify-content-between mb-2">
                      <div>
                        <h6 class="text-light fw-bold mb-1"><%= collab.projectType %></h6>
                        <span class="small text-info">
                          <i class="bi bi-person-circle me-1"></i><%= collab.senderName %> &bull; 
                          <span class="text-warning fw-semibold"><%= collab.role %> Needed</span>
                        </span>
                      </div>
                      <% 
                        let statusBadge = 'status-badge-open';
                        if (collab.status === 'In Review') statusBadge = 'status-badge-in-review';
                        if (collab.status === 'Accepted') statusBadge = 'status-badge-accepted';
                        if (collab.status === 'Closed') statusBadge = 'status-badge-closed';
                      %>
                      <span class="badge <%= statusBadge %> rounded-pill px-3 py-1">
                        <%= collab.status %>
                      </span>
                    </div>

                    <p class="card-text text-secondary small mb-3 p-2 rounded-3 border border-secondary border-opacity-25" style="background: rgba(10, 12, 22, 0.4); backdrop-filter: blur(8px);">
                      "<%= collab.message %>"
                    </p>

                    <div class="d-flex align-items-center justify-content-between text-muted small" style="font-size: 0.75rem;">
                      <span><i class="bi bi-clock me-1"></i>Posted <%= new Date(collab.createdAt).toLocaleDateString() %></span>
                      <a href="mailto:<%= collab.senderEmail %>" class="btn btn-glass btn-sm rounded-pill px-3 text-info" style="font-size: 0.75rem;">
                        <i class="bi bi-envelope-fill me-1"></i> Contact <%= collab.senderName %>
                      </a>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>

        <!-- Right Column: Collaboration Request Submission Form -->
        <div class="col-lg-5">
          <div class="card glass-panel text-light p-4 rounded-4 shadow-lg">
            <h4 class="h5 fw-bold text-warning mb-3 d-flex align-items-center gap-2">
              <i class="bi bi-mic-fill"></i> Post a Collab Request
            </h4>
            <p class="text-muted small mb-4">Are you looking for a singer, guitarist, or producer? Submit your callout to the hub.</p>

            <form action="/collab/new" method="POST" class="needs-validation" novalidate>
              <div class="mb-3">
                <label for="senderName" class="form-label small text-light fw-semibold">Your Name *</label>
                <input type="text" class="form-control echo-input" id="senderName" name="senderName" placeholder="e.g., Alex Vance" required>
                <div class="invalid-feedback small">Please provide your name.</div>
              </div>

              <div class="mb-3">
                <label for="senderEmail" class="form-label small text-light fw-semibold">Your Email *</label>
                <input type="email" class="form-control echo-input" id="senderEmail" name="senderEmail" placeholder="alex@example.com" required>
                <div class="invalid-feedback small">Please provide a valid email.</div>
              </div>

              <div class="row g-2 mb-3">
                <div class="col-md-6">
                  <label for="role" class="form-label small text-light fw-semibold">Role Needed *</label>
                  <select class="form-select echo-input" id="role" name="role" required>
                    <option value="" disabled selected>Select role...</option>
                    <option value="Vocalist">Vocalist</option>
                    <option value="Guitarist">Guitarist</option>
                    <option value="Producer">Producer</option>
                    <option value="Songwriter">Songwriter</option>
                    <option value="Other">Other</option>
                  </select>
                  <div class="invalid-feedback small">Select a role.</div>
                </div>

                <div class="col-md-6">
                  <label for="projectType" class="form-label small text-light fw-semibold">Project Type *</label>
                  <input type="text" class="form-control echo-input" id="projectType" name="projectType" placeholder="e.g. Acoustic EP" required>
                  <div class="invalid-feedback small">Required.</div>
                </div>
              </div>

              <div class="mb-3">
                <label for="message" class="form-label small text-light fw-semibold">Project Details & Message *</label>
                <textarea class="form-control echo-input" id="message" name="message" rows="3" placeholder="Describe your track idea, genre, key, tempo, or what stems you need..." required></textarea>
                <div class="invalid-feedback small">Please enter project details.</div>
              </div>

              <button type="submit" class="btn btn-warning fw-bold w-100 rounded-3 py-2 shadow">
                <i class="bi bi-send-fill me-1"></i> Publish Collaboration Call
              </button>
            </form>
          </div>
        </div>

      </div>
    </section>

  </main>

  <!-- Include Footer -->
  <%- include('partials/footer') %>

  <!-- Bootstrap 5 JS Bundle CDN -->
  <script href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

  <!-- Custom Client JS -->
  <script src="/js/main.js"></script>
</body>
</html>
