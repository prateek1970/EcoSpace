<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EchoSpace — Live @ NICE Grounds, Bengaluru</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #1D0324; color: #FFD2E1; }
    .font-bebas { font-family: 'Bebas Neue', sans-serif; }
    .glow-pink { text-shadow: 0 0 20px #FF007F, 0 0 40px #FF007F; }
    .glow-green { text-shadow: 0 0 15px #39FF14, 0 0 30px #39FF14; }
    .glass-card { background: rgba(53, 11, 66, 0.75); backdrop-filter: blur(14px); border: 1px solid rgba(255, 0, 127, 0.25); }
    .glass-nav { background: rgba(29, 3, 36, 0.85); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255, 210, 225, 0.15); }
  </style>
</head>
<body class="overflow-x-hidden min-h-screen">

  <!-- NAVBAR -->
  <nav class="sticky top-0 z-40 glass-nav px-4 py-3.5">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <span class="font-bebas text-3xl text-[#FFD2E1] glow-pink tracking-wider">ECHOSPACE</span>
        <span class="text-[10px] bg-[#FF007F]/20 text-[#39FF14] border border-[#39FF14]/40 px-2 py-0.5 rounded-full font-bold uppercase">Bengaluru 2026</span>
      </a>

      <div class="hidden md:flex items-center space-x-6 text-xs uppercase font-bold tracking-widest text-[#FFD2E1]">
        <a href="#lineup" class="hover:text-[#39FF14] transition-colors">Lineup & Tickets</a>
        <a href="#sponsors" class="hover:text-[#39FF14] transition-colors">Sponsors</a>
        <a href="#contest" class="hover:text-[#39FF14] transition-colors">Meet & Greet</a>
        <a href="https://maps.app.goo.gl/6MrFUyDMXawU311L8" target="_blank" class="hover:text-[#39FF14] transition-colors">📍 Venue Map</a>
      </div>

      <div class="flex items-center gap-3">
        <% if (locals.user) { %>
          <span class="text-xs text-[#39FF14] font-bold hidden sm:inline">👤 <%= user.name || user.emailOrPhone %></span>
          <a href="/auth/logout" class="px-4 py-2 bg-[#350B42] hover:bg-[#FF007F]/30 text-xs font-bold text-[#FFD2E1] border border-[#FF007F]/40 rounded-full transition-all">Logout</a>
        <% } else { %>
          <a href="/auth/login" class="px-4 py-2 bg-[#FF007F] hover:bg-[#E6399B] text-xs font-bold text-white uppercase tracking-wider rounded-full shadow-[0_0_12px_#FF007F] transition-all">OTP Login</a>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- HERO SECTION WITH CANVAS PARTICLE ENGINE -->
  <header class="relative min-h-[85vh] flex flex-col items-center justify-center text-center px-4 overflow-hidden">
    <!-- 35+ Particle Canvas -->
    <canvas id="particle-canvas" class="absolute inset-0 w-full h-full pointer-events-none opacity-60 z-0"></canvas>

    <!-- Ambient Neon Background Glows -->
    <div class="absolute w-[600px] h-[600px] bg-[#FF007F] opacity-20 blur-[160px] rounded-full pointer-events-none"></div>
    <div class="absolute w-[450px] h-[450px] bg-[#00F0FF] opacity-15 blur-[140px] rounded-full pointer-events-none -top-20 right-10"></div>

    <span class="z-10 px-4 py-1.5 bg-[#FF007F]/20 text-[#39FF14] border border-[#39FF14]/40 rounded-full text-xs font-bold uppercase tracking-widest mb-4">
      📍 NICE Grounds, Bengaluru • 27 July – 03 Aug 2026
    </span>

    <h1 class="z-10 font-bebas text-7xl sm:text-9xl text-[#FFD2E1] glow-pink tracking-tight leading-none">
      ECHOSPACE FESTIVAL
    </h1>

    <p class="z-10 text-[#C994A7] text-sm sm:text-lg max-w-2xl mt-4">
      India's largest concert arena featuring A.R. Rahman, Coldplay, Ed Sheeran, Justin Bieber, Maroon 5, Arijit Singh & more live at <a href="https://maps.app.goo.gl/6MrFUyDMXawU311L8" target="_blank" class="text-[#39FF14] underline font-bold">NICE Grounds</a>.
    </p>

    <div class="z-10 flex flex-wrap justify-center gap-4 mt-8">
      <a href="#lineup" class="px-8 py-3.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-full uppercase tracking-widest shadow-[0_0_20px_#FF007F] transition-all">
        Book Tickets (from ₹2,000)
      </a>
      <a href="https://maps.app.goo.gl/6MrFUyDMXawU311L8" target="_blank" class="px-8 py-3.5 bg-[#350B42] hover:bg-[#FF007F]/40 text-[#FFD2E1] border border-[#FF007F]/40 font-bold rounded-full uppercase tracking-widest transition-all">
        📍 Get Venue Location
      </a>
    </div>
  </header>

  <!-- SPONSORS RIBBON -->
  <section id="sponsors" class="py-8 bg-[#17021D] border-y border-[#FF007F]/20 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="text-xs uppercase font-bold text-[#C994A7] tracking-widest mb-6">OFFICIAL SPONSORS & PARTNERS</p>
      
      <div class="flex flex-wrap justify-center items-center gap-4 sm:gap-6">
        <!-- 1st Image: Jio -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/jio.png" alt="Jio" class="max-h-full object-contain">
        </div>

        <!-- 2nd Image: Airtel -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/airtel.png" alt="Airtel" class="max-h-full object-contain">
        </div>

        <!-- 3rd Image: Blinkit -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/blinkit.png" alt="Blinkit" class="max-h-full object-contain">
        </div>

        <!-- 4th Image: Zepto -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/zepto.png" alt="Zepto" class="max-h-full object-contain">
        </div>

        <!-- 5th Image: Instamart -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/instamart.png" alt="Instamart" class="max-h-full object-contain">
        </div>

        <!-- 6th Image: Starbucks -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/starbucks.png" alt="Starbucks" class="max-h-full object-contain">
        </div>

        <!-- 7th Image: IndiGo -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/indigo.png" alt="IndiGo" class="max-h-full object-contain">
        </div>

        <!-- 8th Image: Qatar Airways -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/qatar_airways.png" alt="Qatar Airways" class="max-h-full object-contain">
        </div>

        <!-- 9th Image: Akasa Air -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/akasa_air.png" alt="Akasa Air" class="max-h-full object-contain">
        </div>

        <!-- 10th Image: Pizza Hut -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/pizza_hut.png" alt="Pizza Hut" class="max-h-full object-contain">
        </div>

        <!-- 11th Image: Domino's -->
        <div class="bg-white/95 hover:bg-white p-2.5 sm:p-3 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_15px_rgba(255,0,127,0.2)] hover:scale-105 hover:shadow-[0_0_20px_#FF007F] transition-all flex items-center justify-center h-14 sm:h-16 px-4">
          <img src="/images/sponsors/dominos.png" alt="Domino's" class="max-h-full object-contain">
        </div>
      </div>
    </div>
  </section>

  <!-- LINEUP & SCHEDULE GRID -->
  <section id="lineup" class="py-16 max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="font-bebas text-5xl sm:text-6xl text-[#FFD2E1] tracking-wide">OFFICIAL SCHEDULE & STAGE LINEUP</h2>
      <p class="text-[#C994A7] text-sm">Select your concert to lock in General Admission or VIP Passes.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <!-- ARTIST 1 & 2 (JULY 27) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=600" alt="AR Rahman & Maroon 5" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">STAGE A & B • 27 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">AR RAHMAN & MAROON 5</h3>
          <p class="text-xs text-[#C994A7] my-2">Dual stage opening night spectacle live at NICE Grounds.</p>
        </div>
        <button onclick="openBooking('AR Rahman & Maroon 5', '27 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Buy Ticket (from ₹2,000)
        </button>
      </div>

      <!-- ARTIST 3 (JULY 28) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="https://images.unsplash.com/photo-1470225620780-dba8ba36b745?w=600" alt="Justin Bieber" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">MAIN STAGE • 28 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">JUSTIN BIEBER</h3>
          <p class="text-xs text-[#C994A7] my-2">Justice World Tour arena stop in Bengaluru.</p>
        </div>
        <button onclick="openBooking('Justin Bieber', '28 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Buy Ticket (from ₹2,000)
        </button>
      </div>

      <!-- ARTIST 4 (JULY 29) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=600" alt="Shreya Ghoshal" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">MAIN STAGE • 29 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">SHREYA GHOSHAL</h3>
          <p class="text-xs text-[#C994A7] my-2">Symphonic melody night with grand live orchestra.</p>
        </div>
        <button onclick="openBooking('Shreya Ghoshal', '29 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Buy Ticket (from ₹2,000)
        </button>
      </div>

      <!-- ARTIST 5 (JULY 30) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=600" alt="Anuv Jain" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">ACOUSTIC ARENA • 30 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">ANUV JAIN</h3>
          <p class="text-xs text-[#C994A7] my-2">Intimate indie acoustic night under the stars.</p>
        </div>
        <button onclick="openBooking('Anuv Jain', '30 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Buy Ticket (from ₹2,000)
        </button>
      </div>

      <!-- ARTIST 6 (JULY 31) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="https://images.unsplash.com/photo-1520523839897-bd0b52f945a0?w=600" alt="Ed Sheeran" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">MAIN STAGE • 31 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">ED SHEERAN</h3>
          <p class="text-xs text-[#C994A7] my-2">+-=÷x Mathematics Tour Live setup.</p>
        </div>
        <button onclick="openBooking('Ed Sheeran', '31 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Buy Ticket (from ₹2,000)
        </button>
      </div>

      <!-- ARTIST 7 (AUG 1) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=600" alt="Coldplay" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">GRAND STAGE • 01 AUG (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">COLDPLAY</h3>
          <p class="text-xs text-[#C994A7] my-2">Music of the Spheres Stadium Experience & LED Wristbands.</p>
        </div>
        <button onclick="openBooking('Coldplay', '01 August 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Buy Ticket (from ₹2,000)
        </button>
      </div>

      <!-- ARTIST 8 (AUG 2) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="https://images.unsplash.com/photo-1508700115892-45ecd05ae2ad?w=600" alt="Alan Walker" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">EDM DOME • 02 AUG (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">ALAN WALKER</h3>
          <p class="text-xs text-[#C994A7] my-2">WalkerWorld laser lights & electronic dance show.</p>
        </div>
        <button onclick="openBooking('Alan Walker', '02 August 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Buy Ticket (from ₹2,000)
        </button>
      </div>

      <!-- ARTIST 9 (AUG 3) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="https://images.unsplash.com/photo-1465847899084-d164df4dedc6?w=600" alt="Arijit Singh" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">GRAND FINALE • 03 AUG (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">ARIJIT SINGH</h3>
          <p class="text-xs text-[#C994A7] my-2">Grand finale night with full orchestra & laser show.</p>
        </div>
        <button onclick="openBooking('Arijit Singh', '03 August 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Buy Ticket (from ₹2,000)
        </button>
      </div>

    </div>
  </section>

  <!-- LUCKY DRAW CONTEST & MEET & GREET SECTION -->
  <section id="contest" class="py-16 bg-[#17021D] border-t border-[#FF007F]/20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <span class="px-3 py-1 bg-[#39FF14]/20 text-[#39FF14] text-xs font-bold rounded-full uppercase">EXCLUSIVE PASS</span>
      <h2 class="font-bebas text-5xl text-white mt-2">WIN EXCLUSIVE MERCH & ARTIST MEET-AND-GREET</h2>
      <p class="text-[#C994A7] text-xs sm:text-sm mb-8">Enter the EchoSpace lucky draw to win official tour hoodies and a photo pass with your favorite artist on show day!</p>

      <form id="contest-form" onsubmit="handleContest(event)" class="glass-card p-6 rounded-2xl text-left space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input type="text" id="cName" placeholder="Full Name" required class="w-full p-3 bg-[#1D0324] border border-[#FF007F]/30 rounded-lg text-white text-xs focus:outline-none focus:border-[#39FF14]">
          <input type="text" id="cContact" placeholder="Mobile Number or Gmail" required class="w-full p-3 bg-[#1D0324] border border-[#FF007F]/30 rounded-lg text-white text-xs focus:outline-none focus:border-[#39FF14]">
        </div>
        <select id="cArtist" required class="w-full p-3 bg-[#1D0324] border border-[#FF007F]/30 rounded-lg text-white text-xs focus:outline-none focus:border-[#39FF14]">
          <option value="">Select Favorite Artist for Meet & Greet</option>
          <option value="AR Rahman & Maroon 5">AR Rahman & Maroon 5 (27 July)</option>
          <option value="Justin Bieber">Justin Bieber (28 July)</option>
          <option value="Shreya Ghoshal">Shreya Ghoshal (29 July)</option>
          <option value="Anuv Jain">Anuv Jain (30 July)</option>
          <option value="Ed Sheeran">Ed Sheeran (31 July)</option>
          <option value="Coldplay">Coldplay (01 Aug)</option>
          <option value="Alan Walker">Alan Walker (02 Aug)</option>
          <option value="Arijit Singh">Arijit Singh (03 Aug)</option>
        </select>
        <textarea id="cReason" rows="3" placeholder="Why do you deserve the photo pass?" required class="w-full p-3 bg-[#1D0324] border border-[#FF007F]/30 rounded-lg text-white text-xs focus:outline-none focus:border-[#39FF14]"></textarea>

        <button type="submit" class="w-full py-3 bg-[#39FF14] hover:bg-[#2ed60f] text-black font-bold uppercase text-xs rounded-lg tracking-wider transition-all">
          Submit Lucky Entry
        </button>
      </form>
      <div id="contest-alert" class="hidden mt-4 p-3 bg-[#39FF14]/20 border border-[#39FF14] text-[#39FF14] rounded-lg text-xs font-bold"></div>
    </div>
  </section>

  <!-- BOOKING & UPI PAYMENT MODAL -->
  <div id="booking-modal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md z-50 flex items-center justify-center p-4">
    <div class="glass-card max-w-md w-full p-6 rounded-2xl relative">
      <button onclick="closeBooking()" class="absolute top-4 right-4 text-white text-xl hover:text-[#FF007F]">✕</button>

      <h3 id="modal-artist" class="font-bebas text-3xl text-white">BOOK TICKETS</h3>
      <p id="modal-date" class="text-xs text-[#39FF14] mb-4"></p>

      <div class="space-y-4 text-xs">
        <div>
          <label class="block text-[#C994A7] mb-1">Your Name</label>
          <input type="text" id="bName" placeholder="Full Name" class="w-full p-2.5 bg-[#1D0324] border border-[#FF007F]/30 rounded-lg text-white focus:outline-none focus:border-[#39FF14]">
        </div>

        <div>
          <label class="block text-[#C994A7] mb-1">Email or Mobile Number</label>
          <input type="text" id="bContact" placeholder="For E-Ticket delivery" class="w-full p-2.5 bg-[#1D0324] border border-[#FF007F]/30 rounded-lg text-white focus:outline-none focus:border-[#39FF14]">
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[#C994A7] mb-1">Ticket Tier</label>
            <select id="bTier" onchange="updatePrice()" class="w-full p-2.5 bg-[#1D0324] border border-[#FF007F]/30 rounded-lg text-white">
              <option value="GA">General (₹2,000)</option>
              <option value="VIP">VIP Pass (₹15,000)</option>
            </select>
          </div>
          <div>
            <label class="block text-[#C994A7] mb-1">Partner Platform</label>
            <select id="bPlatform" class="w-full p-2.5 bg-[#1D0324] border border-[#FF007F]/30 rounded-lg text-white">
              <option value="BookMyShow">BookMyShow</option>
              <option value="District">District</option>
              <option value="SortMyScene">Sort My Scene</option>
              <option value="Ticket9">Ticket9</option>
            </select>
          </div>
        </div>

        <!-- Dynamic Total -->
        <div class="p-3 bg-[#1D0324] rounded-lg border border-[#39FF14]/30 flex justify-between items-center">
          <span>Total Amount:</span>
          <span id="bTotal" class="font-bold text-base text-[#39FF14]">₹2,000</span>
        </div>

        <!-- Simulated UPI QR Code -->
        <div class="text-center py-2">
          <p class="text-[10px] text-[#C994A7] mb-2">Scan & Pay using PhonePe, Google Pay, or Paytm</p>
          <img src="https://api.qrserver.com/v1/create-qr-code/?size=130x130&data=upi://pay?pa=echospace@upi&pn=NICEGrounds" class="mx-auto border-2 border-[#FF007F] rounded-lg">
        </div>

        <button onclick="confirmPayment()" class="w-full py-3 bg-[#39FF14] hover:bg-[#2ed60f] text-black font-bold uppercase rounded-lg transition-all">
          I Have Paid — Generate E-Ticket
        </button>
      </div>
    </div>
  </div>

  <!-- E-TICKET POPUP MODAL -->
  <div id="eticket-modal" class="hidden fixed inset-0 bg-black/90 backdrop-blur-md z-50 flex items-center justify-center p-4">
    <div class="bg-white text-black max-w-sm w-full p-6 rounded-2xl relative shadow-2xl border-4 border-[#FF007F]">
      <button onclick="closeETicket()" class="absolute top-2 right-3 text-black font-bold text-lg hover:text-[#FF007F]">✕</button>

      <div class="text-center border-b pb-3 mb-3">
        <span class="text-[10px] font-bold uppercase bg-black text-white px-2 py-0.5 rounded">OFFICIAL E-TICKET</span>
        <h3 class="font-bebas text-2xl text-[#1D0324] mt-1">ECHOSPACE FESTIVAL 2026</h3>
        <p class="text-[10px] text-gray-600">NICE Grounds, Bengaluru</p>
      </div>

      <div class="space-y-1.5 text-xs">
        <p><strong>Booking ID:</strong> <span id="tID" class="font-mono text-purple-700 font-bold"></span></p>
        <p><strong>Attendee:</strong> <span id="tName"></span></p>
        <p><strong>Show:</strong> <span id="tArtist" class="font-bold"></span></p>
        <p><strong>Date & Time:</strong> <span id="tDate"></span> (6:00 PM Gate Entry)</p>
        <p><strong>Pass Tier:</strong> <span id="tTier" class="bg-yellow-200 px-1 rounded font-bold"></span></p>
        <p><strong>Amount Paid:</strong> <span id="tPrice" class="font-bold text-green-700"></span></p>
      </div>

      <div class="text-center my-4 border-t pt-3">
        <img id="tQR" src="" class="mx-auto w-28 h-28 border">
        <p class="text-[9px] text-gray-500 mt-1">Scan at Gate 3 • NICE Grounds Main Entrance</p>
      </div>

      <button onclick="window.print()" class="w-full py-2 bg-black text-white text-xs font-bold uppercase rounded hover:bg-gray-800 transition-all">
        🖨️ Download / Print Ticket
      </button>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="py-8 bg-[#130117] border-t border-[#FF007F]/20 text-center text-xs text-[#C994A7]">
    <div class="max-w-6xl mx-auto px-4 space-y-2">
      <p class="font-bebas text-2xl text-[#FFD2E1] glow-pink">ECHOSPACE FESTIVAL BENGALURU 2026</p>
      <p>Venue: NICE Grounds, Tumkur Road, Bengaluru, Karnataka • <a href="https://maps.app.goo.gl/6MrFUyDMXawU311L8" target="_blank" class="text-[#39FF14] underline">View Google Map</a></p>
      <p>Contact us: (<a href="mailto:echospacemusicfestival2026@email.com" class="text-[#39FF14] underline">echospacemusicfestival2026@email.com</a>) | +91 - 8022334455</p>
      <p class="text-[10px] opacity-70">Official Ticketing Partners: BookMyShow • District • Sort My Scene • Ticket9</p>
    </div>
  </footer>

  <script>
    // Canvas Particle Animation Engine (40 Floating Neon Particles)
    const canvas = document.getElementById('particle-canvas');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let width = canvas.width = canvas.parentElement.offsetWidth;
      let height = canvas.height = canvas.parentElement.offsetHeight;
      
      window.addEventListener('resize', () => {
        if (canvas.parentElement) {
          width = canvas.width = canvas.parentElement.offsetWidth;
          height = canvas.height = canvas.parentElement.offsetHeight;
        }
      });

      const colors = ['#FF007F', '#39FF14', '#00F0FF', '#FFD2E1'];
      const particles = Array.from({ length: 40 }, () => ({
        x: Math.random() * width,
        y: Math.random() * height,
        radius: Math.random() * 2.5 + 1,
        color: colors[Math.floor(Math.random() * colors.length)],
        vx: (Math.random() - 0.5) * 0.8,
        vy: (Math.random() - 0.5) * 0.8,
        alpha: Math.random() * 0.7 + 0.3
      }));

      function animateParticles() {
        ctx.clearRect(0, 0, width, height);
        particles.forEach(p => {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > width) p.vx *= -1;
          if (p.y < 0 || p.y > height) p.vy *= -1;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.alpha;
          ctx.shadowBlur = 10;
          ctx.shadowColor = p.color;
          ctx.fill();
        });
        requestAnimationFrame(animateParticles);
      }
      animateParticles();
    }

    let selectedArtist = '';
    let selectedDate = '';

    function openBooking(artist, date) {
      selectedArtist = artist;
      selectedDate = date;
      document.getElementById('modal-artist').innerText = artist;
      document.getElementById('modal-date').innerText = '📅 ' + date + ' • NICE Grounds, Bengaluru';
      document.getElementById('booking-modal').classList.remove('hidden');
    }

    function closeBooking() { document.getElementById('booking-modal').classList.add('hidden'); }
    function closeETicket() { document.getElementById('eticket-modal').classList.add('hidden'); }

    function updatePrice() {
      const tier = document.getElementById('bTier').value;
      document.getElementById('bTotal').innerText = tier === 'VIP' ? '₹15,000' : '₹2,000';
    }

    async function confirmPayment() {
      const name = document.getElementById('bName').value.trim();
      const contact = document.getElementById('bContact').value.trim();
      const tier = document.getElementById('bTier').value;
      const platform = document.getElementById('bPlatform').value;

      if (!name || !contact) {
        alert('Please fill in your name and contact details.');
        return;
      }

      const response = await fetch('/api/tickets/book', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userName: name,
          userEmailOrPhone: contact,
          artistName: selectedArtist,
          eventDate: selectedDate,
          tier: tier,
          partnerPlatform: platform
        })
      });

      const data = await response.json();
      if (data.success) {
        closeBooking();
        document.getElementById('tID').innerText = data.ticket.bookingId;
        document.getElementById('tName').innerText = data.ticket.userName;
        document.getElementById('tArtist').innerText = data.ticket.artistName;
        document.getElementById('tDate').innerText = data.ticket.eventDate;
        document.getElementById('tTier').innerText = data.ticket.tier + ' PASS';
        document.getElementById('tPrice').innerText = '₹' + data.ticket.totalAmount;
        document.getElementById('tQR').src = data.ticket.qrCodeUrl;
        document.getElementById('eticket-modal').classList.remove('hidden');
      } else {
        alert(data.message || 'Payment processing failed.');
      }
    }

    async function handleContest(e) {
      e.preventDefault();
      const res = await fetch('/api/contest/entry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: document.getElementById('cName').value,
          emailOrPhone: document.getElementById('cContact').value,
          favoriteArtist: document.getElementById('cArtist').value,
          reason: document.getElementById('cReason').value
        })
      });
      const data = await res.json();
      const alertBox = document.getElementById('contest-alert');
      alertBox.innerText = data.message;
      alertBox.classList.remove('hidden');
      if (data.success) {
        document.getElementById('contest-form').reset();
      }
    }
  </script>
</body>
</html>
