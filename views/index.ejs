<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EchoSpace — Live @ NICE Grounds, Bengaluru</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #1D0324; color: #FFD2E1; }
    .font-bebas { font-family: 'Bebas Neue', sans-serif; }
    .glow-pink { text-shadow: 0 0 20px #FF007F, 0 0 40px #FF007F; }
    .glow-green { text-shadow: 0 0 15px #39FF14, 0 0 30px #39FF14; }
    .glass-card { background: rgba(53, 11, 66, 0.75); backdrop-filter: blur(14px); border: 1px solid rgba(255, 0, 127, 0.25); }
    .glass-nav { background: rgba(29, 3, 36, 0.85); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255, 210, 225, 0.15); }
  </style>
</head>
<body class="overflow-x-hidden min-h-screen">

  <!-- NAVBAR -->
  <nav class="sticky top-0 z-40 glass-nav px-4 py-3.5">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <span class="font-bebas text-3xl text-[#FFD2E1] glow-pink tracking-wider">ECHOSPACE MUSIC</span>
        <span class="text-[10px] bg-[#FF007F]/20 text-[#39FF14] border border-[#39FF14]/40 px-2 py-0.5 rounded-full font-bold uppercase">Bengaluru 2026</span>
      </a>

      <div class="hidden md:flex items-center space-x-6 text-xs uppercase font-bold tracking-widest text-[#FFD2E1]">
        <a href="#lineup" class="hover:text-[#39FF14] transition-colors">Lineup & Tickets</a>
        <a href="#sponsors" class="hover:text-[#39FF14] transition-colors">Sponsors</a>
        <a href="#contest" class="hover:text-[#39FF14] transition-colors">Meet & Win</a>
        <a href="https://maps.app.goo.gl/6MrFUyDMXawU311L8" target="_blank" class="hover:text-[#39FF14] transition-colors">📍 Venue Map</a>
      </div>

      <div class="flex items-center gap-3">
        <% if (locals.user) { %>
          <span class="text-xs text-[#39FF14] font-bold hidden sm:inline">👤 <%= user.name || user.emailOrPhone %></span>
          <a href="/auth/logout" class="px-4 py-2 bg-[#350B42] hover:bg-[#FF007F]/30 text-xs font-bold text-[#FFD2E1] border border-[#FF007F]/40 rounded-full transition-all">Logout</a>
        <% } else { %>
          <a href="/auth/login" class="px-4 py-2 bg-[#FF007F] hover:bg-[#E6399B] text-xs font-bold text-white uppercase tracking-wider rounded-full shadow-[0_0_12px_#FF007F] transition-all">User Login</a>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- HERO SECTION WITH CANVAS PARTICLE ENGINE -->
  <header class="relative min-h-[85vh] flex flex-col items-center justify-center text-center px-4 overflow-hidden">
    <!-- 35+ Particle Canvas -->
    <canvas id="particle-canvas" class="absolute inset-0 w-full h-full pointer-events-none opacity-60 z-0"></canvas>

    <!-- Ambient Neon Background Glows -->
    <div class="absolute w-[600px] h-[600px] bg-[#FF007F] opacity-20 blur-[160px] rounded-full pointer-events-none"></div>
    <div class="absolute w-[450px] h-[450px] bg-[#00F0FF] opacity-15 blur-[140px] rounded-full pointer-events-none -top-20 right-10"></div>

    <span class="z-10 px-4 py-1.5 bg-[#FF007F]/20 text-[#39FF14] border border-[#39FF14]/40 rounded-full text-xs font-bold uppercase tracking-widest mb-4">
      📍 NICE Grounds, Bengaluru • 27 July – 04 Aug 2026
    </span>

    <h1 class="z-10 font-bebas text-7xl sm:text-9xl text-[#FFD2E1] glow-pink tracking-tight leading-none">
      ECHOSPACE MUSIC FESTIVAL 2026
    </h1>

    <p class="z-10 text-[#C994A7] text-sm sm:text-lg max-w-2xl mt-4">
      India's largest concert arena featuring A.R. Rahman, Coldplay, Ed Sheeran, Justin Bieber, Maroon 5, Arijit Singh & more live at <a href="https://maps.app.goo.gl/6MrFUyDMXawU311L8" target="_blank" class="text-[#39FF14] underline font-bold">NICE Grounds</a>.
    </p>

    <div class="z-10 flex flex-wrap justify-center gap-4 mt-8">
      <a href="#lineup" class="px-8 py-3.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-full uppercase tracking-widest shadow-[0_0_20px_#FF007F] transition-all">
        Book Tickets
      </a>
      <a href="https://maps.app.goo.gl/6MrFUyDMXawU311L8" target="_blank" class="px-8 py-3.5 bg-[#350B42] hover:bg-[#FF007F]/40 text-[#FFD2E1] border border-[#FF007F]/40 font-bold rounded-full uppercase tracking-widest transition-all">
        📍 Get Venue Location
      </a>
    </div>
  </header>

  <!-- SPONSORS RIBBON -->
  <section id="sponsors" class="py-12 bg-[#17021D] border-y border-[#FF007F]/20 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h2 class="font-bebas text-5xl sm:text-6xl text-[#FFD2E1] tracking-wide mb-8 uppercase">OFFICIAL SPONSORS & PARTNERS</h2>
      
      <div class="flex flex-wrap justify-center items-start gap-6 sm:gap-8 lg:gap-10">
        <!-- 1st Image: Jio -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/jio.png" alt="Jio" class="w-full h-full object-cover rounded-xl">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">JioCinema</span>
        </div>

        <!-- 2nd Image: Airtel -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/airtel.png" alt="Airtel" class="w-full h-full object-cover rounded-xl">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Zomato</span>
        </div>

        <!-- 3rd Image: Blinkit -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/blinkit.png" alt="Blinkit" class="w-full h-full object-cover rounded-xl">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Blinkit</span>
        </div>

        <!-- 4th Image: Zepto -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/zepto.png" alt="Zepto" class="w-full h-full object-cover rounded-xl">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Zepto</span>
        </div>

        <!-- 5th Image: Instamart -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/instamart.png" alt="Instamart" class="w-full h-full object-cover rounded-xl">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Instamart</span>
        </div>

        <!-- 6th Image: Starbucks -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-2 sm:p-2.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/starbucks.png" alt="Starbucks" class="w-full h-full object-contain p-0.5">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Starbucks</span>
        </div>

        <!-- 7th Image: IndiGo -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/indigo.png" alt="IndiGo" class="w-full h-full object-cover rounded-xl">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">IndiGo</span>
        </div>

        <!-- 8th Image: Qatar Airways -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/qatar_airways.png" alt="Qatar Airways" class="w-full h-full object-cover rounded-xl">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Qatar Airways</span>
        </div>

        <!-- 9th Image: Akasa Air -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/akasa_air.png" alt="Akasa Air" class="w-full h-full object-cover rounded-xl">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Akasa Air</span>
        </div>

        <!-- 10th Image: Pizza Hut -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/pizza_hut.png" alt="Pizza Hut" class="w-full h-full object-contain p-1 scale-110">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Pizza Hut</span>
        </div>

        <!-- 11th Image: Domino's -->
        <div class="flex flex-col items-center group cursor-pointer">
          <div class="bg-white hover:bg-white p-1 sm:p-1.5 rounded-2xl border border-[#FF007F]/30 shadow-[0_0_20px_rgba(255,0,127,0.25)] group-hover:scale-105 group-hover:shadow-[0_0_25px_#FF007F] transition-all flex items-center justify-center h-24 sm:h-28 w-44 sm:w-56 overflow-hidden">
            <img src="/images/sponsors/dominos.png" alt="Domino's" class="w-full h-full object-contain p-1 scale-110">
          </div>
          <span class="mt-2.5 text-xs sm:text-sm font-extrabold tracking-wider text-[#FFD2E1] group-hover:text-[#39FF14] transition-colors uppercase">Domino's</span>
        </div>
      </div>
    </div>
  </section>

  <!-- LINEUP & SCHEDULE GRID -->
  <section id="lineup" class="py-16 max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="font-bebas text-5xl sm:text-6xl text-[#FFD2E1] tracking-wide">OFFICIAL SCHEDULE & STAGE LINEUP</h2>
      <p class="text-[#C994A7] text-sm">Select your concert to lock in General Admission or VIP Passes.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- ARTIST 1 (JULY 27) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/ar_rahman.jpg" alt="AR Rahman" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">MAIN STAGE • 27 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">AR RAHMAN</h3>
          <p class="text-xs text-[#C994A7] my-2">Symphonic opening night spectacle live at NICE Grounds.</p>
        </div>
        <button onclick="openBooking('AR Rahman', '27 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

      <!-- ARTIST 2 (JULY 28) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/justin_bieber.jpg" alt="Justin Bieber" class="w-full h-48 object-cover object-top rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">MAIN STAGE • 28 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">JUSTIN BIEBER</h3>
          <p class="text-xs text-[#C994A7] my-2">Justice World Tour arena stop in Bengaluru.</p>
        </div>
        <button onclick="openBooking('Justin Bieber', '28 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

      <!-- ARTIST 3 (JULY 29) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/shreya_ghoshal.jpg" alt="Shreya Ghoshal" class="w-full h-48 object-cover object-center rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">MAIN STAGE • 29 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">SHREYA GHOSHAL</h3>
          <p class="text-xs text-[#C994A7] my-2">Symphonic melody night with grand live orchestra.</p>
        </div>
        <button onclick="openBooking('Shreya Ghoshal', '29 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

      <!-- ARTIST 4 (JULY 30) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/anuv_jain.jpg" alt="Anuv Jain" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">ACOUSTIC ARENA • 30 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">ANUV JAIN</h3>
          <p class="text-xs text-[#C994A7] my-2">Intimate indie acoustic night under the stars.</p>
        </div>
        <button onclick="openBooking('Anuv Jain', '30 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

      <!-- ARTIST 5 (JULY 31) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/ed_sheeran.jpg" alt="Ed Sheeran" class="w-full h-48 object-cover object-top rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">MAIN STAGE • 31 JULY (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">ED SHEERAN</h3>
          <p class="text-xs text-[#C994A7] my-2">+-=÷x Mathematics Tour Live setup.</p>
        </div>
        <button onclick="openBooking('Ed Sheeran', '31 July 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

      <!-- ARTIST 6 (AUG 1) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/coldplay.webp" alt="Coldplay" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">GRAND STAGE • 01 AUG (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">COLDPLAY</h3>
          <p class="text-xs text-[#C994A7] my-2">Music of the Spheres Stadium Experience & LED Wristbands.</p>
        </div>
        <button onclick="openBooking('Coldplay', '01 August 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

      <!-- ARTIST 7 (AUG 2) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/alan_walker.jpg" alt="Alan Walker" class="w-full h-48 object-cover object-[center_25%] rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">EDM DOME • 02 AUG (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">ALAN WALKER</h3>
          <p class="text-xs text-[#C994A7] my-2">WalkerWorld laser lights & electronic dance show.</p>
        </div>
        <button onclick="openBooking('Alan Walker', '02 August 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

      <!-- ARTIST 8 (AUG 3) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/arijit_singh.jpg" alt="Arijit Singh" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">GRAND FINALE • 03 AUG (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">ARIJIT SINGH</h3>
          <p class="text-xs text-[#C994A7] my-2">Emotional Bollywood acoustic night & hits collection.</p>
        </div>
        <button onclick="openBooking('Arijit Singh', '03 August 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

      <!-- ARTIST 9 (AUG 4) -->
      <div class="glass-card rounded-2xl overflow-hidden p-5 flex flex-col justify-between hover:border-[#FF007F] transition-all">
        <img src="/images/artists/maroon5.webp" alt="Maroon 5" class="w-full h-48 object-cover rounded-xl mb-4">
        <div>
          <span class="text-xs font-bold text-[#39FF14] uppercase">MEGA CLOSING • 04 AUG (6 PM - 10 PM)</span>
          <h3 class="font-bebas text-3xl text-white mt-1">MAROON 5</h3>
          <p class="text-xs text-[#C994A7] my-2">Grand finale night with full band hits & laser extravaganza.</p>
        </div>
        <button onclick="openBooking('Maroon 5', '04 August 2026')" class="w-full mt-4 py-2.5 bg-[#FF007F] hover:bg-[#E6399B] text-white font-bold rounded-lg uppercase tracking-wider text-xs shadow-[0_0_15px_#FF007F] transition-all">
          Book Tickets
        </button>
      </div>

    </div>
  </section>

  <!-- LUCKY DRAW CONTEST & MEET & GREET SECTION -->
  <section id="contest" class="py-16 bg-[#17021D] border-t border-[#FF007F]/20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <span class="px-3 py-1 bg-[#39FF14]/20 text-[#39FF14] text-xs font-bold rounded-full uppercase">EXCLUSIVE PASS</span>
      <h2 class="font-bebas text-5xl text-white mt-2">WIN EXCLUSIVE MERCH & ARTIST MEET-AND-GREET</h2>
      <p class="text-[#C994A7] text-xs sm:text-sm mb-8">Enter the EchoSpace lucky draw to win official tour hoodies and a photo pass with your favorite artist on show day!</p>

      <form id="contest-form" onsubmit="handleContest(event)" class="glass-card p-6 rounded-2xl text-left space-y-4">
