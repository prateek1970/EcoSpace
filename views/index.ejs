  <script>
    // Canvas Particle Animation Engine (40 Floating Neon Particles)
    const canvas = document.getElementById('particle-canvas');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let width = canvas.width = canvas.parentElement.offsetWidth;
      let height = canvas.height = canvas.parentElement.offsetHeight;

      window.addEventListener('resize', () => {
        if (canvas.parentElement) {
          width = canvas.width = canvas.parentElement.offsetWidth;
          height = canvas.height = canvas.parentElement.offsetHeight;
        }
      });

      const colors = ['#FF007F', '#39FF14', '#00F0FF', '#FFD2E1'];
      const particles = Array.from({ length: 40 }, () => ({
        x: Math.random() * width,
        y: Math.random() * height,
        radius: Math.random() * 2.5 + 1,
        color: colors[Math.floor(Math.random() * colors.length)],
        vx: (Math.random() - 0.5) * 0.8,
        vy: (Math.random() - 0.5) * 0.8,
        alpha: Math.random() * 0.7 + 0.3
      }));

      function animateParticles() {
        ctx.clearRect(0, 0, width, height);
        particles.forEach(p => {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > width) p.vx *= -1;
          if (p.y < 0 || p.y > height) p.vy *= -1;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.alpha;
          ctx.shadowBlur = 10;
          ctx.shadowColor = p.color;
          ctx.fill();
        });
        requestAnimationFrame(animateParticles);
      }
      animateParticles();
    }

    let selectedArtist = '';
    let selectedDate = '';
    let selectedEventId = '';
    let currentBookingId = '';

    function openBooking(artist, date, eventId = '') {
      selectedArtist = artist;
      selectedDate = date;
      selectedEventId = eventId;
      document.getElementById('modal-artist').innerText = artist;
      document.getElementById('modal-date').innerText = '📅 ' + date + ' • NICE Grounds, Bengaluru';
      
      // Reset steps
      document.getElementById('step-intent').classList.remove('hidden');
      document.getElementById('step-upi-qr').classList.add('hidden');
      document.getElementById('bQuantity').value = 1;
      updatePrice();
      document.getElementById('booking-modal').classList.remove('hidden');
    }

    function closeBooking() { document.getElementById('booking-modal').classList.add('hidden'); }
    function closeETicket() { document.getElementById('eticket-modal').classList.add('hidden'); }

    function updatePrice() {
      const tier = document.getElementById('bTier').value;
      const qty = parseInt(document.getElementById('bQuantity').value) || 1;
      const unitPrice = tier === 'VIP' ? 15000 : 2000;
      const total = unitPrice * qty;
      document.getElementById('bTotal').innerText = '₹' + total.toLocaleString('en-IN');
    }

    // Step 1: Create Booking Intent & Generate upi://pay QR
    async function createBookingIntent() {
      const name = document.getElementById('bName').value.trim();
      const contact = document.getElementById('bContact').value.trim();
      const tier = document.getElementById('bTier').value;
      const quantity = parseInt(document.getElementById('bQuantity').value) || 1;
      const platform = document.getElementById('bPlatform').value;

      if (!name || !contact) {
        alert('Please enter your Name and Contact (Email/Phone) to generate ticket.');
        return;
      }

      try {
        const response = await fetch('/api/tickets/intent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            userName: name,
            userContact: contact,
            eventId: selectedEventId,
            artistName: selectedArtist,
            eventDate: selectedDate,
            tier: tier,
            quantity: quantity,
            partnerPlatform: platform
          })
        });

        const data = await response.json();
        if (data.success) {
          currentBookingId = data.bookingId;
          document.getElementById('intent-booking-id').innerText = data.bookingId;
          document.getElementById('upi-qr-image').src = data.qrCodeImageUrl;
          document.getElementById('upi-deep-link-btn').href = data.upiDeepLink;

          document.getElementById('step-intent').classList.add('hidden');
          document.getElementById('step-upi-qr').classList.remove('hidden');
        } else {
          alert(data.message || 'Failed to initialize payment.');
        }
      } catch (err) {
        console.error('Intent Error:', err);
        alert('Network error initializing payment intent.');
      }
    }

    // Step 2: Confirm Payment & Render Official E-Ticket
    async function confirmPayment() {
      if (!currentBookingId) {
        alert('Booking session expired. Please re-open ticket booking.');
        return;
      }

      const upiRef = document.getElementById('bUpiRef').value.trim();

      try {
        const response = await fetch('/api/tickets/confirm', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            bookingId: currentBookingId,
            upiTxnRef: upiRef
          })
        });

        const data = await response.json();
        if (data.success) {
          closeBooking();
          document.getElementById('tID').innerText = data.ticket.bookingId;
          document.getElementById('tName').innerText = data.ticket.userName;
          if (document.getElementById('tContact')) document.getElementById('tContact').innerText = data.ticket.userContact;
          document.getElementById('tArtist').innerText = data.ticket.artistName;
          document.getElementById('tDate').innerText = data.ticket.eventDate;
          document.getElementById('tTier').innerText = data.ticket.tier + ' PASS';
          if (document.getElementById('tQty')) document.getElementById('tQty').innerText = data.ticket.quantity || 1;
          if (document.getElementById('tPlatform')) document.getElementById('tPlatform').innerText = data.ticket.partnerPlatform || 'BookMyShow';
          document.getElementById('tPrice').innerText = '₹' + (data.ticket.totalAmount || data.ticket.price).toLocaleString('en-IN');
          if (document.getElementById('tRef')) document.getElementById('tRef').innerText = data.ticket.upiTxnRef || 'CONFIRMED';
          document.getElementById('tQR').src = data.ticket.qrCodeUrl;
          document.getElementById('eticket-modal').classList.remove('hidden');
        } else {
          alert(data.message || 'Payment confirmation failed.');
        }
      } catch (err) {
        console.error('Confirm Error:', err);
        alert('Network error confirming payment.');
      }
    }

    async function handleContest(e) {
      e.preventDefault();
      const name = document.getElementById('cName').value.trim();
      const contact = document.getElementById('cContact').value.trim();
      const artist = document.getElementById('cArtist').value;
      const reason = document.getElementById('cReason').value.trim();

      if (!name || !contact || !artist || !reason) {
        alert('Please fill out all fields in the contest entry form.');
        return;
      }

      try {
        const res = await fetch('/api/contest/entry', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, contact, favoriteArtist: artist, reason })
        });
        const data = await res.json();
        const alertBox = document.getElementById('contest-alert');
        alertBox.innerText = data.message;
        alertBox.classList.remove('hidden');
        if (data.success) {
          document.getElementById('contest-form').reset();
        }
      } catch (err) {
        console.error('Contest Error:', err);
        alert('Network error submitting contest entry.');
      }
    }

    async function handleSendOTP() {
      const target = document.getElementById('loginTarget').value.trim();
      if (!target) return alert('Please enter your mobile number or Gmail.');
      try {
        const res = await fetch('/send-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ emailOrPhone: target })
        });
        const data = await res.json();
        const alertBox = document.getElementById('login-alert');
        alertBox.innerText = data.message;
        alertBox.classList.remove('hidden');
        if (data.success) {
          document.getElementById('otpInputGroup').classList.remove('hidden');
        }
      } catch (err) {
        console.error('Send OTP Error:', err);
        alert('Network error sending OTP.');
      }
    }

    async function handleVerifyOTP() {
      const target = document.getElementById('loginTarget').value.trim();
      const otp = document.getElementById('otpCode').value.trim();
      if (!target || !otp) return alert('Please enter OTP code.');
      try {
        const res = await fetch('/verify-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ emailOrPhone: target, otp })
        });
        const data = await res.json();
        const alertBox = document.getElementById('login-alert');
        alertBox.innerText = data.message;
        alertBox.classList.remove('hidden');
        if (data.success) {
          setTimeout(() => { window.location.href = data.redirectUrl || '/'; }, 800);
        }
      } catch (err) {
        console.error('Verify OTP Error:', err);
        alert('Network error verifying OTP.');
      }
    }

    async function handleInstantLogin() {
      const target = document.getElementById('loginTarget').value.trim() || 'creator@gmail.com';
      try {
        const res = await fetch('/instant-login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ emailOrPhone: target })
        });
        const data = await res.json();
        const alertBox = document.getElementById('login-alert');
        alertBox.innerText = data.message;
        alertBox.classList.remove('hidden');
        if (data.success) {
          setTimeout(() => { window.location.href = data.redirectUrl || '/'; }, 500);
        }
      } catch (err) {
        console.error('Instant Login Error:', err);
        alert('Network error during instant login.');
      }
    }
  </script>
