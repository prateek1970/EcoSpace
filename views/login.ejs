<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login & Authentication | EchoSpace</title>

  <!-- Google Fonts: Bebas Neue, Montserrat, Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            plum: '#1D0324',
            violet: '#280732',
            magenta: '#350B42',
            dustyPink: '#FFD2E1',
            neonPink: '#FF007F',
            laserGreen: '#39FF14',
            cyanLight: '#00F0FF',
            softPink: '#F9CBD9',
            mutedRose: '#C994A7'
          },
          fontFamily: {
            display: ['Bebas Neue', 'sans-serif'],
            header: ['Montserrat', 'sans-serif'],
            sans: ['Inter', 'sans-serif']
          }
        }
      }
    }
  </script>

  <!-- Festival Design System Stylesheet -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-[#1D0324] text-white font-sans antialiased selection:bg-[#FF007F] selection:text-white min-h-screen flex flex-col justify-between">

  <!-- Floating Particles & Background Glow -->
  <div class="fixed inset-0 pointer-events-none z-0">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-[#FF007F]/20 blur-[150px] rounded-full"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-[#39FF14]/15 blur-[140px] rounded-full"></div>
  </div>

  <!-- Top Navbar Header -->
  <header class="relative z-20 px-6 py-5 max-w-7xl mx-auto w-full flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="w-9 h-9 rounded-full bg-gradient-to-tr from-[#FF007F] to-[#39FF14] flex items-center justify-center text-[#1D0324] font-black text-xl shadow-[0_0_15px_#FF007F]">
        ⚡
      </span>
      <span class="font-display text-2xl text-[#FFD2E1] tracking-widest leading-none group-hover:text-[#39FF14] transition-colors">
        ECHOSPACE
      </span>
    </a>
    <a href="/" class="text-xs font-header tracking-wider text-[#F9CBD9] hover:text-[#FF007F] transition-colors">
      ← Back to Main Showcase
    </a>
  </header>

  <!-- Main Auth Card Container -->
  <main class="relative z-10 max-w-md w-full mx-auto px-4 py-8">
    <div class="glass-panel rounded-3xl p-8 sm:p-10 border border-[#FF007F]/40 shadow-[0_0_40px_rgba(255,0,127,0.3)] text-center relative overflow-hidden">
      
      <!-- Top Badge -->
      <span class="inline-block px-3.5 py-1 rounded-full text-[10px] font-header font-extrabold tracking-widest uppercase bg-[#39FF14] text-[#1D0324] mb-3">
        SECURE CREATOR LOGIN
      </span>

      <!-- Title -->
      <h1 class="font-display text-5xl text-[#FFD2E1] tracking-wider mb-1 drop-shadow-[0_0_15px_#FF007F]">
        ACCESS ECHOSPACE
      </h1>
      <p class="text-xs text-[#C994A7] mb-6">
        Enter any Mobile Number or Gmail. No pre-set password required!
      </p>

      <!-- Auth Form Container -->
      <div class="auth-container text-left">
        
        <!-- Step 1: Input Mobile/Gmail -->
        <form id="step-send-otp" onsubmit="event.preventDefault(); handleSendOTP();" class="space-y-4">
          <div>
            <label class="text-[10px] font-header uppercase tracking-widest text-[#F9CBD9] block mb-1">
              Mobile Number or Gmail *
            </label>
            <input
              type="text"
              id="emailOrPhone"
              value="creator@gmail.com"
              placeholder="Enter Mobile Number or Gmail"
              class="w-full px-4 py-3 rounded-xl bg-[#1D0324] border border-[#FFD2E1]/20 text-white placeholder-gray-500 text-xs focus:outline-none focus:border-[#FF007F] transition-colors"
            />
          </div>
          <button
            type="submit"
            id="btn-send-otp"
            class="w-full py-3.5 rounded-full btn-neon font-header text-xs tracking-widest uppercase shadow-[0_0_20px_#FF007F]"
          >
            Send OTP Code
          </button>
        </form>

        <!-- Quick 1-Click Login Option -->
        <div class="mt-4 pt-4 border-t border-white/10 text-center">
          <button
            type="button"
            onclick="handleQuickLogin()"
            class="w-full py-3 rounded-full bg-[#350B42] hover:bg-[#FF007F]/30 border border-[#39FF14]/50 text-[#39FF14] font-header text-xs tracking-widest uppercase transition-all shadow-[0_0_15px_rgba(57,255,20,0.2)]"
          >
            ⚡ Quick 1-Click Instant Login
          </button>
        </div>

        <!-- Step 2: Input OTP (Initially Hidden) -->
        <form id="step-verify-otp" onsubmit="event.preventDefault(); handleVerifyOTP();" style="display: none;" class="space-y-4 mt-4">
          <div id="debugOtpNotice" class="p-3 rounded-xl bg-[#39FF14]/10 border border-[#39FF14] text-[#39FF14] text-xs font-mono text-center font-bold" style="display: none;"></div>
          
          <div>
            <label class="text-[10px] font-header uppercase tracking-widest text-[#39FF14] block mb-1">
              Enter 6-Digit OTP *
            </label>
            <input
              type="text"
              id="otpInput"
              placeholder="Enter 6-Digit OTP"
              maxlength="6"
              class="w-full px-4 py-3 rounded-xl bg-[#1D0324] border border-[#39FF14]/40 text-center font-mono text-lg text-[#39FF14] tracking-widest focus:outline-none focus:border-[#39FF14]"
            />
          </div>
          <button
            type="submit"
            id="btn-verify-otp"
            class="w-full py-3.5 rounded-full btn-neon-green font-header text-xs tracking-widest uppercase shadow-[0_0_20px_#39FF14]"
          >
            Verify & Enter
          </button>
        </form>

        <!-- Alert Notification Box -->
        <div id="auth-alert" style="display: none;"></div>

      </div>

    </div>
  </main>

  <!-- Footer -->
  <footer class="relative z-10 py-6 text-center text-[11px] text-[#C994A7] font-mono">
    © 2026 ECHOSPACE AUTHENTICATION SYSTEM
  </footer>

  <!-- Client-Side Auth Script -->
  <script src="/js/auth.js"></script>
</body>
</html>
