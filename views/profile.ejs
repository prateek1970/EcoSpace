<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile | Echo Showcase Hub</title>
  
  <!-- Bootstrap 5 CSS CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  
  <!-- Bootstrap Icons CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-dark text-light d-flex flex-column min-vh-100 position-relative">

  <!-- Ambient Glass Background Glowing Orbs -->
  <div class="ambient-glow-container">
    <div class="ambient-orb ambient-orb-1"></div>
    <div class="ambient-orb ambient-orb-2"></div>
    <div class="ambient-orb ambient-orb-3"></div>
  </div>

  <!-- Include Navbar -->
  <%- include('partials/navbar') %>

  <main class="flex-grow-1 py-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

          <!-- Message Alerts -->
          <% if (message) { %>
            <div class="alert alert-success d-flex align-items-center gap-2 rounded-4 mb-4" role="alert">
              <i class="bi bi-check-circle-fill fs-4"></i>
              <div><%= message %></div>
            </div>
          <% } %>
          <% if (error) { %>
            <div class="alert alert-danger d-flex align-items-center gap-2 rounded-4 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill fs-4"></i>
              <div><%= error %></div>
            </div>
          <% } %>

          <!-- Profile Header Card -->
          <div class="glass-panel rounded-4 p-4 p-md-5 shadow-lg mb-4 position-relative overflow-hidden">
            <!-- Decorative gradient accent -->
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #ffc107 0%, #a855f7 50%, #06b6d4 100%); border-radius: 16px 16px 0 0;"></div>
            
            <div class="d-flex flex-column flex-md-row align-items-center gap-4">
              <!-- Avatar -->
              <div class="profile-avatar d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" 
                   style="width: 100px; height: 100px; background: linear-gradient(135deg, rgba(255, 193, 7, 0.2), rgba(168, 85, 247, 0.2)); border: 2px solid rgba(255, 193, 7, 0.4); box-shadow: 0 0 30px rgba(255, 193, 7, 0.2);">
                <span class="display-4 fw-bold text-warning"><%= user.name.charAt(0).toUpperCase() %></span>
              </div>

              <!-- User Info -->
              <div class="text-center text-md-start flex-grow-1">
                <h1 class="h2 fw-bold text-light mb-1"><%= user.name %></h1>
                <p class="text-muted small mb-2">EchoHub Creator since <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>
                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-md-start">
                  <span class="badge rounded-pill px-3 py-2" style="background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.35); color: #4ade80;">
                    <i class="bi bi-patch-check-fill me-1"></i> Verified Account
                  </span>
                  <span class="badge btn-glass rounded-pill px-3 py-2">
                    <i class="bi bi-music-note-beamed me-1 text-warning"></i> Creator
                  </span>
                </div>
              </div>

              <!-- Actions -->
              <div class="d-flex flex-column gap-2">
                <a href="/" class="btn btn-warning btn-sm fw-bold rounded-pill px-4 shadow-sm">
                  <i class="bi bi-play-circle-fill me-1"></i> Explore Tracks
                </a>
                <a href="/auth/logout" class="btn btn-glass btn-sm rounded-pill px-4 text-danger">
                  <i class="bi bi-box-arrow-right me-1"></i> Logout
                </a>
              </div>
            </div>
          </div>

          <!-- Profile Details Grid -->
          <div class="row g-4">
            
            <!-- Contact Details Card -->
            <div class="col-md-6">
              <div class="glass-panel rounded-4 p-4 shadow h-100">
                <h5 class="fw-bold text-light mb-3 d-flex align-items-center gap-2">
                  <i class="bi bi-person-lines-fill text-warning"></i> Contact Details
                </h5>
                
                <div class="d-flex flex-column gap-3">
                  <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                    <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: rgba(255, 193, 7, 0.15); border: 1px solid rgba(255, 193, 7, 0.3);">
                      <i class="bi bi-envelope-fill text-warning"></i>
                    </div>
                    <div>
                      <small class="text-muted d-block">Email Address</small>
                      <span class="text-light fw-semibold"><%= user.email %></span>
                    </div>
                    <% if (user.isEmailVerified) { %>
                      <i class="bi bi-check-circle-fill text-success ms-auto" title="Verified"></i>
                    <% } %>
                  </div>

                  <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                    <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 40px; height: 40px; background: rgba(6, 182, 212, 0.15); border: 1px solid rgba(6, 182, 212, 0.3);">
                      <i class="bi bi-phone-fill text-info"></i>
                    </div>
                    <div>
                      <small class="text-muted d-block">Mobile Number</small>
                      <span class="text-light fw-semibold"><%= user.mobile %></span>
                    </div>
                    <% if (user.isMobileVerified) { %>
                      <i class="bi bi-check-circle-fill text-success ms-auto" title="Verified"></i>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>

            <!-- Account Status Card -->
            <div class="col-md-6">
              <div class="glass-panel rounded-4 p-4 shadow h-100">
                <h5 class="fw-bold text-light mb-3 d-flex align-items-center gap-2">
                  <i class="bi bi-shield-fill-check text-success"></i> Verification Status
                </h5>

                <div class="d-flex flex-column gap-3">
                  <div class="d-flex align-items-center justify-content-between p-3 rounded-3" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                    <div class="d-flex align-items-center gap-2">
                      <i class="bi bi-envelope-check text-warning"></i>
                      <span class="small text-light">Email Verification</span>
                    </div>
                    <span class="badge rounded-pill px-3 py-1 <%= user.isEmailVerified ? 'bg-success bg-opacity-25 text-success border border-success border-opacity-50' : 'bg-danger bg-opacity-25 text-danger border border-danger border-opacity-50' %>">
                      <%= user.isEmailVerified ? 'Verified' : 'Pending' %>
                    </span>
                  </div>

                  <div class="d-flex align-items-center justify-content-between p-3 rounded-3" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                    <div class="d-flex align-items-center gap-2">
                      <i class="bi bi-phone-vibrate text-info"></i>
                      <span class="small text-light">Mobile Verification</span>
                    </div>
                    <span class="badge rounded-pill px-3 py-1 <%= user.isMobileVerified ? 'bg-success bg-opacity-25 text-success border border-success border-opacity-50' : 'bg-danger bg-opacity-25 text-danger border border-danger border-opacity-50' %>">
                      <%= user.isMobileVerified ? 'Verified' : 'Pending' %>
                    </span>
                  </div>

                  <div class="d-flex align-items-center justify-content-between p-3 rounded-3" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                    <div class="d-flex align-items-center gap-2">
                      <i class="bi bi-calendar3 text-muted"></i>
                      <span class="small text-light">Member Since</span>
                    </div>
                    <span class="small text-muted"><%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <!-- Quick Navigation -->
          <div class="glass-panel rounded-4 p-4 shadow mt-4">
            <h5 class="fw-bold text-light mb-3 d-flex align-items-center gap-2">
              <i class="bi bi-grid-fill text-warning"></i> Quick Actions
            </h5>
            <div class="d-flex flex-wrap gap-3">
              <a href="/" class="btn btn-glass rounded-pill px-4">
                <i class="bi bi-disc me-1 text-warning"></i> Browse Showcase
              </a>
              <a href="/#collab-section" class="btn btn-glass rounded-pill px-4">
                <i class="bi bi-people me-1 text-info"></i> Collab Hub
              </a>
              <a href="/admin" class="btn btn-glass rounded-pill px-4">
                <i class="bi bi-sliders me-1 text-danger"></i> Studio Admin
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

  <!-- Include Footer -->
  <%- include('partials/footer') %>

  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  <script src="/js/main.js"></script>
</body>
</html>
