<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Studio Admin Panel | Echo Showcase Hub</title>
  
  <!-- Bootstrap 5 CSS CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  
  <!-- Bootstrap Icons CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-dark text-light d-flex flex-column min-vh-100 position-relative">

  <!-- Ambient Glass Background Glowing Orbs -->
  <div class="ambient-glow-container">
    <div class="ambient-orb ambient-orb-1"></div>
    <div class="ambient-orb ambient-orb-2"></div>
    <div class="ambient-orb ambient-orb-3"></div>
  </div>

  <!-- Include Navbar -->
  <%- include('partials/navbar') %>

  <!-- Admin Header Banner -->
  <div class="hero-wrapper py-4 border-bottom border-secondary border-opacity-25 mb-4">
    <div class="container">
      <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
          <span class="badge bg-danger text-light px-3 py-1 rounded-pill fw-bold text-uppercase tracking-wider mb-2 shadow-sm">
            <i class="bi bi-shield-lock-fill me-1"></i> Admin Dashboard
          </span>
          <h1 class="h2 text-light fw-bold mb-0">Studio & Showcase Management</h1>
        </div>
        <div>
          <a href="/" class="btn btn-glass rounded-pill px-4">
            <i class="bi bi-eye me-1"></i> View Live Site
          </a>
        </div>
      </div>
    </div>
  </div>

  <main class="container py-2">

    <!-- Flash Alert Messages -->
    <% if (message) { %>
      <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 rounded-4" role="alert">
        <i class="bi bi-check-circle-fill fs-4"></i>
        <div><%= message %></div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 rounded-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
        <div><%= error %></div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- Admin Overview Quick Stats Bar -->
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="p-4 glass-panel rounded-4 d-flex align-items-center justify-content-between shadow-sm">
          <div>
            <span class="text-muted small">Total Showcase Tracks</span>
            <h3 class="fw-bold text-warning mb-0"><%= tracks.length %></h3>
          </div>
          <i class="bi bi-disc fs-1 text-warning opacity-75"></i>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-4 glass-panel rounded-4 d-flex align-items-center justify-content-between shadow-sm">
          <div>
            <span class="text-muted small">Collab Requests</span>
            <h3 class="fw-bold text-info mb-0"><%= collabRequests.length %></h3>
          </div>
          <i class="bi bi-people fs-1 text-info opacity-75"></i>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-4 glass-panel rounded-4 d-flex align-items-center justify-content-between shadow-sm">
          <div>
            <span class="text-muted small">Open Projects</span>
            <h3 class="fw-bold text-success mb-0"><%= collabRequests.filter(c => c.status === 'Open').length %></h3>
          </div>
          <i class="bi bi-check-circle fs-1 text-success opacity-75"></i>
        </div>
      </div>
    </div>

    <!-- Section 1: Add New Track Form -->
    <div class="card glass-panel text-light mb-5 rounded-4 shadow-lg">
      <div class="card-header card-header-gradient p-3 d-flex align-items-center justify-content-between">
        <h3 class="h5 fw-bold text-warning mb-0 d-flex align-items-center gap-2">
          <i class="bi bi-plus-circle-fill"></i> Upload / Add New Track
        </h3>
        <span class="text-muted small">Post new acoustic audio stems or covers</span>
      </div>
      <div class="card-body p-4">
        <form action="/admin/tracks/add" method="POST" class="needs-validation" novalidate>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="title" class="form-label text-light small fw-semibold">Track Title *</label>
              <input type="text" class="form-control echo-input" id="title" name="title" placeholder="e.g. Midnight Guitar Session" required>
              <div class="invalid-feedback">Track title is required.</div>
            </div>

            <div class="col-md-6">
              <label for="artistName" class="form-label text-light small fw-semibold">Artist / Creator Name</label>
              <input type="text" class="form-control echo-input" id="artistName" name="artistName" placeholder="Default: Solo Artist">
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <label for="category" class="form-label text-light small fw-semibold">Category *</label>
              <select class="form-select echo-input" id="category" name="category" required>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat %>"><%= cat %></option>
                <% }); %>
              </select>
            </div>

            <div class="col-md-8">
              <label for="audioUrl" class="form-label text-light small fw-semibold">Audio MP3 Direct URL *</label>
              <input type="url" class="form-control echo-input" id="audioUrl" name="audioUrl" placeholder="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" required>
              <div class="invalid-feedback">A valid direct audio MP3 URL is required.</div>

              <!-- Quick Demo Audio Presets Buttons -->
              <div class="mt-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small" style="font-size: 0.75rem;">Sample Demo Presets:</span>
                <button type="button" class="btn btn-glass btn-sm preset-audio-btn py-1 px-2 rounded-pill" style="font-size: 0.75rem;" data-url="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3">
                  Preset 1 (SoundHelix 1)
                </button>
                <button type="button" class="btn btn-glass btn-sm preset-audio-btn py-1 px-2 rounded-pill" style="font-size: 0.75rem;" data-url="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3">
                  Preset 2 (SoundHelix 2)
                </button>
                <button type="button" class="btn btn-glass btn-sm preset-audio-btn py-1 px-2 rounded-pill" style="font-size: 0.75rem;" data-url="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3">
                  Preset 3 (SoundHelix 3)
                </button>
              </div>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-8">
              <label for="description" class="form-label text-light small fw-semibold">Description</label>
              <input type="text" class="form-control echo-input" id="description" name="description" placeholder="Short description, key, tuning (e.g. Standard E), recording gear used...">
            </div>

            <div class="col-md-4">
              <label for="tags" class="form-label text-light small fw-semibold">Tags (Comma Separated)</label>
              <input type="text" class="form-control echo-input" id="tags" name="tags" placeholder="acoustic, fingerstyle, solo">
            </div>
          </div>

          <div class="d-flex justify-content-end">
            <button type="submit" class="btn btn-warning fw-bold px-4 py-2 rounded-3 shadow">
              <i class="bi bi-cloud-upload-fill me-1"></i> Publish Track to Showcase
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Section 2: Manage Collaboration Requests Table -->
    <div class="card glass-panel text-light mb-5 rounded-4 shadow-lg">
      <div class="card-header card-header-gradient p-3 d-flex align-items-center justify-content-between">
        <h3 class="h5 fw-bold text-info mb-0 d-flex align-items-center gap-2">
          <i class="bi bi-people-fill"></i> Manage Collaboration Requests
        </h3>
        <span class="badge bg-info text-dark rounded-pill px-3 py-1 fw-bold"><%= collabRequests.length %> Total</span>
      </div>

      <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0">
          <thead class="table-secondary">
            <tr>
              <th scope="col" class="ps-3">Project / Sender</th>
              <th scope="col">Role Needed</th>
              <th scope="col">Message & Details</th>
              <th scope="col">Current Status</th>
              <th scope="col" class="text-end pe-3">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (collabRequests.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center py-4 text-muted">No collaboration requests available yet.</td>
              </tr>
            <% } else { %>
              <% collabRequests.forEach(collab => { %>
                <tr>
                  <td class="ps-3">
                    <div class="fw-bold text-light"><%= collab.projectType %></div>
                    <div class="small text-muted">
                      <%= collab.senderName %> (<a href="mailto:<%= collab.senderEmail %>" class="text-info text-decoration-none"><%= collab.senderEmail %></a>)
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-dark bg-opacity-50 border border-secondary border-opacity-25 text-warning px-3 py-1">
                      <%= collab.role %>
                    </span>
                  </td>
                  <td>
                    <div class="small text-secondary text-truncate" style="max-width: 280px;" title="<%= collab.message %>">
                      <%= collab.message %>
                    </div>
                  </td>
                  <td>
                    <!-- Status Update Form -->
                    <form action="/admin/collab/<%= collab._id %>/status" method="POST" class="d-inline-flex align-items-center gap-1">
                      <select name="status" class="form-select form-select-sm echo-input py-1" onchange="this.form.submit()">
                        <% statuses.forEach(st => { %>
                          <option value="<%= st %>" <%= collab.status === st ? 'selected' : '' %>><%= st %></option>
                        <% }); %>
                      </select>
                    </form>
                  </td>
                  <td class="text-end pe-3">
                    <form action="/admin/collab/<%= collab._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this collaboration request?')">
                      <button type="submit" class="btn btn-glass btn-sm text-danger rounded-circle" title="Delete Request">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Section 3: Manage Existing Tracks Table -->
    <div class="card glass-panel text-light mb-4 rounded-4 shadow-lg">
      <div class="card-header card-header-gradient p-3 d-flex align-items-center justify-content-between">
        <h3 class="h5 fw-bold text-light mb-0 d-flex align-items-center gap-2">
          <i class="bi bi-disc-fill text-warning"></i> Existing Showcase Tracks
        </h3>
        <span class="badge bg-warning text-dark rounded-pill px-3 py-1 fw-bold"><%= tracks.length %> Tracks</span>
      </div>

      <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0">
          <thead class="table-secondary">
            <tr>
              <th scope="col" class="ps-3">Track Info</th>
              <th scope="col">Category</th>
              <th scope="col">Likes</th>
              <th scope="col">Created Date</th>
              <th scope="col" class="text-end pe-3">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (tracks.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center py-4 text-muted">No tracks found. Upload a track above!</td>
              </tr>
            <% } else { %>
              <% tracks.forEach(tr => { %>
                <tr>
                  <td class="ps-3">
                    <div class="fw-bold text-light"><%= tr.title %></div>
                    <div class="small text-muted"><i class="bi bi-person me-1"></i><%= tr.artistName %></div>
                  </td>
                  <td>
                    <span class="badge bg-dark bg-opacity-50 text-warning border border-secondary border-opacity-25 px-2 py-1">
                      <%= tr.category %>
                    </span>
                  </td>
                  <td>
                    <span class="fw-bold text-danger"><i class="bi bi-heart-fill me-1"></i><%= tr.likes %></span>
                  </td>
                  <td class="small text-muted">
                    <%= new Date(tr.createdAt).toLocaleDateString() %>
                  </td>
                  <td class="text-end pe-3">
                    <a href="<%= tr.audioUrl %>" target="_blank" class="btn btn-glass btn-sm me-1 rounded-circle text-light" title="Test Audio">
                      <i class="bi bi-play-fill"></i>
                    </a>
                    <form action="/admin/tracks/<%= tr._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this track?')">
                      <button type="submit" class="btn btn-glass btn-sm text-danger rounded-circle" title="Delete Track">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

  <!-- Include Footer -->
  <%- include('partials/footer') %>

  <!-- Bootstrap 5 JS Bundle CDN -->
  <script href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

  <!-- Custom Client JS -->
  <script src="/js/main.js"></script>
</body>
</html>
