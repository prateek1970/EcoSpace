<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Backstage Control Center | EchoSpace Admin</title>

  <!-- Google Fonts: Bebas Neue, Montserrat, Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            plum: '#1D0324',
            violet: '#280732',
            magenta: '#350B42',
            dustyPink: '#FFD2E1',
            neonPink: '#FF007F',
            laserGreen: '#39FF14',
            cyanLight: '#00F0FF',
            softPink: '#F9CBD9',
            mutedRose: '#C994A7'
          },
          fontFamily: {
            display: ['Bebas Neue', 'sans-serif'],
            header: ['Montserrat', 'sans-serif'],
            sans: ['Inter', 'sans-serif']
          }
        }
      }
    }
  </script>

  <!-- Custom Festival CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-[#1D0324] text-white font-sans antialiased selection:bg-[#FF007F] selection:text-white min-h-screen">

  <!-- Background Ambient Glow -->
  <div class="fixed inset-0 pointer-events-none z-0">
    <div class="absolute top-1/4 left-10 w-96 h-96 bg-[#FF007F]/15 blur-[140px] rounded-full" />
    <div class="absolute bottom-1/3 right-10 w-96 h-96 bg-[#39FF14]/15 blur-[140px] rounded-full" />
  </div>

  <!-- Header / Navigation Bar -->
  <header className="sticky top-0 z-40 px-4 sm:px-8 py-4 bg-[#1D0324]/80 backdrop-blur-md border-b border-[#FFD2E1]/15">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <span class="w-10 h-10 rounded-full bg-gradient-to-tr from-[#FF007F] to-[#39FF14] flex items-center justify-center text-[#1D0324] font-black text-2xl shadow-[0_0_15px_#FF007F]">
          ⚡
        </span>
        <div class="flex flex-col">
          <span class="font-display text-2xl sm:text-3xl text-[#FFD2E1] tracking-widest leading-none group-hover:text-[#39FF14] transition-colors">
            ECHOSPACE
          </span>
          <span class="text-[10px] text-[#C994A7] font-mono tracking-wider">
            BACKSTAGE CONTROL CENTER
          </span>
        </div>
      </a>

      <div class="flex items-center gap-4">
        <a href="/" class="px-5 py-2.5 rounded-full bg-[#350B42] border border-[#FF007F]/40 text-[#FFD2E1] font-header text-xs tracking-widest uppercase hover:bg-[#FF007F] hover:text-white transition-all shadow-[0_0_15px_rgba(255,0,127,0.3)]">
          ← View Live Site
        </a>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-8 py-10 relative z-10">

    <!-- Flash Messages -->
    <% if (message) { %>
      <div class="mb-8 p-4 rounded-2xl bg-[#350B42] border border-[#39FF14] text-[#39FF14] flex items-center gap-3 text-sm font-semibold shadow-[0_0_20px_rgba(57,255,20,0.3)]">
        <span class="text-xl">⚡</span>
        <div><%= message %></div>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="mb-8 p-4 rounded-2xl bg-[#350B42] border border-[#FF007F] text-[#FFD2E1] flex items-center gap-3 text-sm font-semibold shadow-[0_0_20px_rgba(255,0,127,0.3)]">
        <span class="text-xl">⚠️</span>
        <div><%= error %></div>
      </div>
    <% } %>

    <!-- Dashboard Title Banner -->
    <div class="mb-10 text-center sm:text-left flex flex-col sm:flex-row items-center justify-between gap-4">
      <div>
        <span class="text-[#39FF14] font-header tracking-[0.3em] text-xs uppercase block mb-1">
          EVENT ORGANIZER DASHBOARD
        </span>
        <h1 class="font-display text-5xl sm:text-6xl text-[#FFD2E1] tracking-wider drop-shadow-[0_0_15px_#FF007F]">
          BACKSTAGE CONTROL
        </h1>
      </div>

      <!-- Quick Metrics -->
      <div class="flex items-center gap-4">
        <div class="glass-panel px-6 py-3 rounded-2xl border border-[#FFD2E1]/20 text-center">
          <span class="text-[10px] text-[#C994A7] font-header uppercase tracking-wider block">SHOWCASE TRACKS</span>
          <span class="font-display text-3xl text-[#39FF14]"><%= tracks.length %></span>
        </div>
        <div class="glass-panel px-6 py-3 rounded-2xl border border-[#FFD2E1]/20 text-center">
          <span class="text-[10px] text-[#C994A7] font-header uppercase tracking-wider block">COLLAB PROPOSALS</span>
          <span class="font-display text-3xl text-[#00F0FF]"><%= collabRequests.length %></span>
        </div>
      </div>
    </div>

    <!-- Grid: Add Track Form & Live Management -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      
      <!-- 1. Track Upload Form (Left Column) -->
      <div class="lg:col-span-5">
        <div class="glass-panel rounded-3xl p-8 border border-[#FF007F]/40 shadow-[0_0_30px_rgba(255,0,127,0.2)]">
          <h2 class="font-header text-2xl text-[#FFD2E1] tracking-wider mb-2 flex items-center gap-2">
            <span class="text-[#FF007F]">🎵</span> UPLOAD NEW TRACK
          </h2>
          <p class="text-xs text-[#C994A7] mb-6">
            Add new audio showcases, acoustic jams, or festival snippets directly to the live feed.
          </p>

          <form action="/admin/tracks/new" method="POST" class="space-y-4">
            <div>
              <label class="text-[10px] font-header uppercase tracking-widest text-[#F9CBD9] block mb-1">Track Title *</label>
              <input
                required
                type="text"
                name="title"
                placeholder="e.g. Midnight Cyber Strum"
                class="w-full px-4 py-3 rounded-xl bg-[#1D0324] border border-[#FFD2E1]/20 text-white placeholder-gray-500 text-xs focus:outline-none focus:border-[#FF007F] transition-colors"
              />
            </div>

            <div>
              <label class="text-[10px] font-header uppercase tracking-widest text-[#F9CBD9] block mb-1">Artist / Stage Name</label>
              <input
                type="text"
                name="artistName"
                placeholder="e.g. Olivia Wilson & The Vibes"
                class="w-full px-4 py-3 rounded-xl bg-[#1D0324] border border-[#FFD2E1]/20 text-white placeholder-gray-500 text-xs focus:outline-none focus:border-[#FF007F] transition-colors"
              />
            </div>

            <div>
              <label class="text-[10px] font-header uppercase tracking-widest text-[#F9CBD9] block mb-1">Category *</label>
              <select
                name="category"
                class="w-full px-4 py-3 rounded-xl bg-[#1D0324] border border-[#FFD2E1]/20 text-white text-xs focus:outline-none focus:border-[#FF007F] transition-colors"
              >
                <% categories.forEach(cat => { %>
                  <option value="<%= cat %>"><%= cat %></option>
                <% }); %>
              </select>
            </div>

            <div>
              <label class="text-[10px] font-header uppercase tracking-widest text-[#F9CBD9] block mb-1">Audio URL (MP3 / Direct Link) *</label>
              <input
                required
                type="url"
                name="audioUrl"
                placeholder="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"
                class="w-full px-4 py-3 rounded-xl bg-[#1D0324] border border-[#FFD2E1]/20 text-white placeholder-gray-500 text-xs focus:outline-none focus:border-[#FF007F] transition-colors"
              />
            </div>

            <div>
              <label class="text-[10px] font-header uppercase tracking-widest text-[#F9CBD9] block mb-1">Description</label>
              <textarea
                name="description"
                rows="3"
                placeholder="Describe tuning, mics, setup, or genre background..."
                class="w-full px-4 py-3 rounded-xl bg-[#1D0324] border border-[#FFD2E1]/20 text-white placeholder-gray-500 text-xs focus:outline-none focus:border-[#FF007F] transition-colors resize-none"
              ></textarea>
            </div>

            <div>
              <label class="text-[10px] font-header uppercase tracking-widest text-[#F9CBD9] block mb-1">Tags (Comma-separated)</label>
              <input
                type="text"
                name="tags"
                placeholder="acoustic, fingerstyle, synth, indie"
                class="w-full px-4 py-3 rounded-xl bg-[#1D0324] border border-[#FFD2E1]/20 text-white placeholder-gray-500 text-xs focus:outline-none focus:border-[#FF007F] transition-colors"
              />
            </div>

            <button
              type="submit"
              class="w-full py-4 mt-4 btn-neon font-header text-xs tracking-widest uppercase shadow-[0_0_25px_#FF007F]"
            >
              Publish to Live Showcase
            </button>
          </form>
        </div>
      </div>

      <!-- 2. Manage Existing Tracks & Collab Board (Right Column) -->
      <div class="lg:col-span-7 space-y-10">
        
        <!-- Live Tracks Management Card -->
        <div class="glass-panel rounded-3xl p-8 border border-[#FFD2E1]/20">
          <h2 class="font-header text-2xl text-[#FFD2E1] tracking-wider mb-6 flex items-center justify-between">
            <span>LIVE SHOWCASE TRACKS (<%= tracks.length %>)</span>
            <span class="text-xs font-mono text-[#39FF14]">● ONLINE</span>
          </h2>

          <% if (tracks.length === 0) { %>
            <div class="p-8 text-center text-[#C994A7] text-xs font-mono border border-dashed border-[#FFD2E1]/20 rounded-2xl">
              No tracks uploaded yet. Use the form to publish your first audio track!
            </div>
          <% } else { %>
            <div class="space-y-4 max-h-[420px] overflow-y-auto pr-2">
              <% tracks.forEach(track => { %>
                <div class="p-4 rounded-2xl bg-[#1D0324]/80 border border-[#FFD2E1]/15 flex items-center justify-between gap-4 hover:border-[#FF007F]/50 transition-colors">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="px-2 py-0.5 rounded text-[9px] font-mono uppercase bg-[#FF007F]/20 text-[#FFD2E1] border border-[#FF007F]/40">
                        <%= track.category %>
                      </span>
                      <span class="text-xs text-[#39FF14] font-mono">❤️ <%= track.likes %> likes</span>
                    </div>
                    <h4 class="font-header text-sm text-white truncate"><%= track.title %></h4>
                    <p class="text-xs text-[#C994A7] truncate">By <%= track.artistName %></p>
                  </div>

                  <form action="/admin/tracks/<%= track._id || track.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to remove this track?');">
                    <button type="submit" class="px-3 py-1.5 rounded-lg bg-red-950/60 border border-red-500/40 text-red-300 text-xs hover:bg-red-900 transition-colors">
                      Delete
                    </button>
                  </form>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>

        <!-- Collab Proposal Board Card -->
        <div class="glass-panel rounded-3xl p-8 border border-[#FFD2E1]/20">
          <h2 class="font-header text-2xl text-[#FFD2E1] tracking-wider mb-6 flex items-center justify-between">
            <span>COLLABORATION PROPOSALS BOARD (<%= collabRequests.length %>)</span>
            <span class="text-xs font-mono text-[#00F0FF]">📥 INBOUND REQUESTS</span>
          </h2>

          <% if (collabRequests.length === 0) { %>
            <div class="p-8 text-center text-[#C994A7] text-xs font-mono border border-dashed border-[#FFD2E1]/20 rounded-2xl">
              No collaboration proposals submitted yet.
            </div>
          <% } else { %>
            <div class="space-y-4 max-h-[500px] overflow-y-auto pr-2">
              <% collabRequests.forEach(collab => { %>
                <div class="p-5 rounded-2xl bg-[#1D0324]/90 border border-[#FFD2E1]/15 space-y-3">
                  <div class="flex items-center justify-between gap-2 flex-wrap">
                    <div>
                      <span class="font-header text-base text-[#FFD2E1]"><%= collab.senderName %></span>
                      <span class="text-xs text-[#C994A7] ml-2">&lt;<%= collab.senderEmail %>&gt;</span>
                    </div>
                    
                    <span class="px-3 py-1 rounded-full text-[10px] font-header font-bold uppercase tracking-wider <%= collab.status === 'Open' ? 'bg-[#39FF14] text-[#1D0324]' : collab.status === 'Accepted' ? 'bg-[#00F0FF] text-[#1D0324]' : 'bg-purple-900 text-purple-200' %>">
                      <%= collab.status %>
                    </span>
                  </div>

                  <div class="flex items-center gap-3 text-xs text-[#F9CBD9] font-mono">
                    <span>ROLE: <strong class="text-[#39FF14]"><%= collab.role %></strong></span>
                    <span>•</span>
                    <span>PROJECT: <strong class="text-[#00F0FF]"><%= collab.projectType %></strong></span>
                  </div>

                  <p class="text-xs text-[#C994A7] italic leading-relaxed bg-[#350B42]/50 p-3 rounded-xl border border-[#FFD2E1]/10">
                    "<%= collab.message %>"
                  </p>

                  <div class="flex items-center justify-between pt-2 border-t border-[#FFD2E1]/10">
                    <!-- Update Status Form -->
                    <form action="/admin/collab/<%= collab._id || collab.id %>/status" method="POST" class="flex items-center gap-2">
                      <select name="status" class="px-3 py-1 rounded-lg bg-[#350B42] border border-[#FFD2E1]/20 text-xs text-white">
                        <% statuses.forEach(st => { %>
                          <option value="<%= st %>" <%= collab.status === st ? 'selected' : '' %>><%= st %></option>
                        <% }); %>
                      </select>
                      <button type="submit" class="px-3 py-1 rounded-lg bg-[#FF007F] text-white text-xs font-header uppercase hover:bg-[#E6399B]">
                        Update
                      </button>
                    </form>

                    <!-- Delete Request -->
                    <form action="/admin/collab/<%= collab._id || collab.id %>/delete" method="POST" onsubmit="return confirm('Delete proposal?');">
                      <button type="submit" class="text-xs text-red-400 hover:text-red-300">
                        Remove
                      </button>
                    </form>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>

      </div>

    </div>

  </main>

  <footer class="mt-20 py-8 border-t border-[#FFD2E1]/15 text-center text-xs text-[#C994A7] font-mono">
    © 2026 ECHOSPACE BACKSTAGE CONTROL • MUSIC CREATOR & COLLAB HUB
  </footer>
</body>
</html>
